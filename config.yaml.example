# Cheroki Configuration
# 이 파일을 config.yaml로 복사한 뒤 환경에 맞게 수정하세요.
# cp config.yaml.example config.yaml

paths:
  originals: "~/cheroki-data/originals/"
  transcripts: "~/cheroki-data/transcripts/"
  corrections: "~/cheroki-data/corrections/"
  corpus: "~/cheroki-data/corpus/"
  exports: "~/cheroki-data/exports/"

  # Hahnness vault 연동 (Phase 3)
  # vault: "/path/to/vault/"
  # vault_log: "/path/to/vault/20 Log/"
  # vault_resources: "/path/to/vault/80 Resources/"

whisper:
  mode: "local"          # "local" (faster-whisper) 또는 "api" (OpenAI)
  model: "medium"        # 로컬 모드: tiny, base, small, medium, large-v3
  language: "ko"
  device: "cpu"          # 로컬 모드: cpu 또는 cuda
  compute_type: "int8"   # 로컬 모드: int8, float16, float32
  # api_model: "whisper-1"  # API 모드에서 사용할 모델

# OpenAI API (whisper.mode: "api" 일 때 필요)
# openai:
#   api_key: "sk-..."

transcription:
  min_confidence: 0.7
  chunk_length: 30

# telegram:
#   bot_token: "YOUR_BOT_TOKEN"
#   allowed_users: []  # 비어있으면 모든 사용자 허용

