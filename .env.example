# Cheroki 환경변수 템플릿
# 이 파일을 .env로 복사하고 실제 값을 채우세요.
# .env는 .gitignore에 포함되어 있어 커밋되지 않습니다.

# === Telegram 봇 ===
# @BotFather에서 발급받은 봇 토큰
BOT_TOKEN=0000000000:AA...

# Local Bot API Server에 필요 (my.telegram.org에서 발급)
# 처음에는 비워둬도 core 라이브러리는 동작합니다.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Local Bot API Server URL (Docker Compose로 실행)
LOCAL_API_URL=http://localhost:8081

# === Deepgram ===
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# === 허용 사용자 Telegram ID (콤마 구분) ===
# 비워두면 모든 사용자가 거부됩니다.
# 자기 ID 확인: @userinfobot에 /start
ALLOWED_USER_IDS=

# === 저장 ===
DATA_DIR=./data
DB_PATH=./data/siltare.db

# === 로그 ===
LOG_LEVEL=INFO
