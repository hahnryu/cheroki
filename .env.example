# Cheroki 환경변수 템플릿
# 이 파일을 .env로 복사하고 실제 값을 채우세요.
# .env는 .gitignore에 포함되어 있어 커밋되지 않습니다.

# === Telegram 봇 ===
# @BotFather에서 발급받은 봇 토큰
BOT_TOKEN=0000000000:AA...

# Local Bot API Server에 필요 (my.telegram.org에서 발급)
# 처음에는 비워둬도 core 라이브러리는 동작합니다.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Local Bot API Server URL. 비워두면 클라우드 Bot API(20MB 제한).
# 값이 있으면 Docker Compose로 실행되는 로컬 서버(2GB까지) 사용.
LOCAL_API_URL=http://localhost:8081

# local 모드에서 telegram-bot-api 컨테이너가 파일을 쓰는 호스트 경로.
# docker-compose.yml의 bind mount target과 일치해야 한다.
# 봇이 getFile 응답의 컨테이너 내부 경로를 이 값으로 치환해서 읽는다.
LOCAL_API_FILES_DIR=./data/tg-api

# === STT provider 선택 ===
# scribe (기본, 한국어 품질 우위) · deepgram (속도 우위)
STT_PROVIDER=scribe

# === ElevenLabs Scribe ===
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=scribe_v2

# === Deepgram (보조 또는 비교 실험용) ===
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# === 허용 사용자 Telegram ID (콤마 구분) ===
# 비워두면 모든 사용자가 거부됩니다.
# 자기 ID 확인: @userinfobot에 /start
ALLOWED_USER_IDS=

# === 저장 ===
DATA_DIR=./data
DB_PATH=./data/siltare.db

# === 로그 ===
LOG_LEVEL=INFO
